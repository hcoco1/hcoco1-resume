---
import BaseLayout from "../layouts/BaseLayout.astro";
import Contactform from "../components/contactform.astro";
---

<BaseLayout title="Contact" sideBarActiveItemID="contact">
  <div class="site-page">
    <header class="page-header">
      <h1 class="page-title">Contact</h1>
      <p class="page-lede">
        Send a message about GIS applications, web projects, cloud infrastructure, or collaboration.
      </p>
    </header>

    <div class="grid gap-6 md:grid-cols-[0.85fr_1.15fr]">
      <aside class="surface-card p-6">
        <h2 class="text-xl font-extrabold text-base-content">Reach me</h2>
        <p class="mt-3 leading-7 text-base-content/70">
          Fill out the form or send an email directly. I usually reply to clear project notes fastest.
        </p>

        <div class="mt-6 space-y-3">
          <div class="flex items-center gap-3 text-base-content/80">
            <svg class="h-5 w-5 text-primary" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 21s7-5.2 7-12a7 7 0 1 0-14 0c0 6.8 7 12 7 12Z" />
              <circle cx="12" cy="9" r="2.5" />
            </svg>
            <span>Zaragoza</span>
          </div>

          <div class="flex items-center gap-3 text-base-content/80">
            <svg class="h-5 w-5 text-primary" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16v12H4z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="m4 7 8 6 8-6" />
            </svg>
            <a class="link-hover font-semibold" href="mailto:arias.ivan@hcoco1.com">arias.ivan@hcoco1.com</a>
          </div>
        </div>
      </aside>

      <div class="surface-card p-6">
        <Contactform />
      </div>
    </div>
  </div>
</BaseLayout>
