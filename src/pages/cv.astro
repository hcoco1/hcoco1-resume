---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<style>
  /* Themed gradient backgrounds — reference DaisyUI oklch tokens, can't use Tailwind utilities */
  .cv-shell {
    background:
      radial-gradient(circle at top right, oklch(var(--p) / 0.12), transparent 34rem),
      linear-gradient(180deg, oklch(var(--b1) / 0.92), oklch(var(--b2) / 0.88));
  }
  .cv-hero {
    background: linear-gradient(135deg, oklch(var(--n) / 0.98), oklch(var(--p) / 0.92));
    padding: clamp(1.4rem, 4vw, 3rem);
  }

  .cv-eyebrow::before {
    content: "";
    display: block;
    width: 2rem;
    height: 2px;
    background: oklch(var(--a) / 1);
  }

  .cv-timeline-item::before {
    content: "";
    position: absolute;
    top: 0.35rem;
    left: 0;
    width: 0.58rem;
    height: 0.58rem;
    border-radius: 50%;
    background: oklch(var(--a) / 1);
    box-shadow: 0 0 0 5px oklch(var(--a) / 0.14);
  }
  .cv-timeline-item:not(:last-child)::after {
    content: "";
    position: absolute;
    top: 1.25rem;
    bottom: -0.65rem;
    left: 0.27rem;
    width: 1px;
    background: oklch(var(--bc) / 0.12);
  }

  .cv-section-title::before {
    content: "";
    flex-shrink: 0;
    width: 0.72rem;
    height: 0.72rem;
    border: 3px solid oklch(var(--p) / 1);
    border-radius: 50%;
    box-shadow: 0 0 0 4px oklch(var(--p) / 0.12);
  }

  .cv-impact-list li::marker {
    color: oklch(var(--p) / 1);
  }

  @media (max-width: 620px) {
    .cv-shell {
      border-radius: 0;
      margin-inline: -1.5rem;
      border-left: 0;
      border-right: 0;
    }
  }
</style>

<BaseLayout title="Resume — Ivan Arias" sideBarActiveItemID="cv">
