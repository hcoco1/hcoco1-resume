  <div class="divider my-0"></div>
  </section>

  <section>
    <div class="page-header">
      <h2 class="page-title">Latest from blog</h2>
    </div>

  {
    last_posts.map((post) => (
      <>
        <HorizontalCard
          title={post.data.title}
          img={post.data.heroImage}
          desc={post.data.description}
          url={"/blog/" + post.slug}
          target="_self"
          badge={post.data.badge}
        />
        <div class="divider my-0" />
      </>
    ))
  }
  </section>
  </div>
</BaseLayout>
