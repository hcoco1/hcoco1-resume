---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const last_posts = posts.slice(0, 3);

const projects = (await getCollection("portfolio")).sort(
  (a, b) => b.data.updatedDate.valueOf() - a.data.updatedDate.valueOf(),
);

const last_projects = projects.slice(0, 3);
---

<BaseLayout sideBarActiveItemID="home">
  <div class="site-page">
  <section class="surface-card p-6 md:p-8">
    <div class="text-sm font-bold uppercase tracking-wide text-primary">Hey there</div>
    <h1 class="mt-2 text-5xl font-black leading-none text-base-content">I'm Ivan</h1>
    <p class="py-3 text-xl font-bold text-base-content/85">Junior GIS Developer | Web GIS • Python • AWS</p>
    <div class="mb-5">
    <p class="max-w-3xl text-pretty leading-8 text-base-content/75">
      Geological engineer with 13+ years of experience in geospatial analysis and subsurface data interpretation,
      transitioning into Web GIS development. Experienced with <span class="font-bold text-primary">ArcGIS</span>, spatial data modeling,
      and modern technologies including Python, cloud systems, and web applications.
      <br><br>
      Currently focused on building scalable GIS applications and data-driven solutions.
    </p>
    </div>
    <div class="mt-8">
      <a class="btn btn-primary" href="https://twitter.com/hcoco1" target="_blank">
        Let's connect!</a
      >
    </div>
  </section>

  <section>
    <div class="page-header">
      <h2 class="page-title">Latest projects</h2>
    </div>

  {
    last_projects.map((item) => (
      <>
        <HorizontalCard
          title={item.data.title}
          img={item.data.heroImage}
          desc={item.data.description}
          url={"/portfolio/" + item.slug}
          target="_self"
          badge={item.data.badge}
        />
        <div class="divider my-0" />
      </>
    ))
  }


