---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SideBar from "../components/SideBar.astro";

import { SITE_TITLE, SITE_DESCRIPTION } from "../config";

const {
  image,
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  includeSidebar = true,
  sideBarActiveItemID,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} image={image} />
    <script is:inline>
      // Prevent FOART: apply saved theme before first paint
      if (localStorage.getItem("theme") === null) {
        document.documentElement.setAttribute("data-theme", "hcoco");
      } else {
        document.documentElement.setAttribute(
          "data-theme",
          localStorage.getItem("theme"),
        );
      }
    </script>
    <!-- Processed by Astro/Vite so the npm import resolves correctly -->
    <script>
      import { themeChange } from "theme-change";
      themeChange();
    </script>
  </head>
  <body>
    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-DT72EQSLX6"></script>
    <script is:inline>
      // @ts-nocheck — GA boilerplate intentionally uses `arguments`
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag("js", new Date());
      gtag("config", "G-DT72EQSLX6");
    </script>
    <div class="drawer min-h-screen bg-base-100 text-base-content lg:drawer-open">
      <input id="my-drawer" type="checkbox" class="drawer-toggle" />
      <div class="drawer-content min-h-screen bg-base-100">
        <Header title={SITE_TITLE} />
        <div class="md:flex md:justify-center">
          <main class="w-full max-w-[100vw] px-5 py-10 md:px-8 lg:max-w-[980px]">
            <slot />
          </main>
        </div>
        <Footer />
      </div>
      {includeSidebar && <SideBar sideBarActiveItemID={sideBarActiveItemID} />}
    </div>
  </body>
</html>
