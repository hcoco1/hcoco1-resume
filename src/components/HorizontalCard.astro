---
const { title, img, desc, url, badge, tags, target = "_blank" } = Astro.props;
import { Image } from "astro:assets";
const tag_url = tags ? url.split("/").slice(0, -1).join("/") + "/tag" : "";
---

<div class="content-card">
  <a href={url} target={target} class="block">
    <div class="flex flex-col items-start gap-4 p-4 md:flex-row">
      {
        img && (
          <Image
            src={img}
            width={750}
            height={422}
            format="webp"
            alt={title}
            class="content-card-image"
          />
        )
      }
      <div class="grow w-full">
        <h2 class="content-card-title">
          {title}
          {badge && <div class="site-badge mx-2">{badge}</div>}
        </h2>
        <p class="content-card-description">{desc}</p>
        <div class="card-actions justify-end">
          {
            tags &&
              tags.map((tag: string) => (
                <a href={`${tag_url}/${tag}`} class="badge badge-outline hover:badge-primary">
                  {tag}
                </a>
              ))
          }
        </div>
      </div>
    </div>
  </a>
</div>
